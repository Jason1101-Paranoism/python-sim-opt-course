{"config":{"lang":["zh"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"Python Simulation &amp; Optimization Pathway","text":"<p>\u5f9e\u6a21\u64ec\u5165\u9580\u5230\u7814\u7a76\u7d1a\u5c08\u984c\u7684\u5b8c\u6574\u5b78\u7fd2\u8def\u5f91</p>"},{"location":"#_1","title":"\u9019\u662f\u4ec0\u9ebc\u8ab2\uff1f","text":"<p>\u4e00\u5957\u91dd\u5c0d\u9ad8\u4e2d\u751f\u8a2d\u8a08\u7684 Python \u6a21\u64ec\u8207\u512a\u5316 \u56db\u7d1a\u8ab2\u7a0b\u3002\u5b78\u751f\u4e0d\u53ea\u5b78\u7a0b\u5f0f\u8a9e\u6cd5\uff0c\u800c\u662f\u5b78\u6703\u7528 Python \u5efa\u6a21\u3001\u6a21\u64ec\u3001\u5206\u6790\u8cc7\u6599\u3001\u5beb\u7814\u7a76\u5831\u544a\u3002</p> <p>\u6bcf\u4e00\u7d1a\u7522\u51fa\u4e00\u4efd\u771f\u5be6\u4f5c\u54c1\uff1a\u53ef\u4ee5\u653e\u9032\u5b78\u7fd2\u6b77\u7a0b\u3001AP/IB \u5831\u544a\u3001\u751a\u81f3\u5927\u5b78\u7533\u8acb\u4f5c\u54c1\u96c6\u3002</p>"},{"location":"#_2","title":"\u56db\u7d1a\u5b78\u7fd2\u8def\u5f91","text":"\u7d1a\u5225 \u8ab2\u7a0b\u540d\u7a31 \u9069\u5408\u5c0d\u8c61 \u6838\u5fc3\u7522\u51fa Level 1 \u6a21\u64ec\u5165\u9580 \u9ad8\u4e00\u6216 Python \u521d\u5b78\u8005 \u96a8\u6a5f\u6a21\u64ec\u5c0f\u5c08\u984c + mini report Level 2 AP/IB \u5c08\u984c \u9700\u8981 IA/EE/side project \u7684\u5b78\u751f \u5b8c\u6574 project \u5831\u544a + \u7c21\u5831 Level 3 \u6578\u503c\u65b9\u6cd5\u8207\u512a\u5316 \u60f3\u6df1\u5165 NumPy/SciPy \u7684\u5b78\u751f \u9032\u968e\u6578\u503c\u6a21\u578b + \u512a\u5316\u5be6\u9a57 Level 4 Research Capstone \u6709\u610f\u7533\u8acb\u7814\u7a76\u578b\u5927\u5b78\u6216\u7af6\u8cfd\u7684\u5b78\u751f \u7814\u7a76\u8ad6\u6587\u7b49\u7d1a\u5831\u544a + \u53e3\u8a66\u6a21\u64ec"},{"location":"#_3","title":"\u70ba\u4ec0\u9ebc\u9078\u9019\u5957\u8ab2\uff1f","text":"\u4e0d\u53ea\u662f\u8a9e\u6cd5\u8ab2\u771f\u5be6\u4f5c\u54c1\u7522\u51fa\u500b\u5225\u6307\u5c0e\u7cfb\u7d71\u5316\u8def\u5f91 <p>\u8ab2\u7a0b\u6838\u5fc3\u662f\u5efa\u6a21\u601d\u7dad\uff0c\u4e0d\u662f\u80cc Python \u8a9e\u6cd5\u3002\u5b78\u751f\u6bcf\u9031\u90fd\u6709\u53ef\u4ee5\u5c55\u793a\u7684\u6771\u897f\u3002</p> <p>\u6bcf\u4e00\u7d1a\u90fd\u6709\u671f\u672b\u6210\u679c\uff1areport\u3001slide\u3001code\u3002\u53ef\u76f4\u63a5\u7528\u65bc\u5b78\u7fd2\u6b77\u7a0b\u8207\u5927\u5b78\u7533\u8acb\u3002</p> <p>\u5c0f\u73ed 4\u20138 \u4eba + \u6bcf\u4eba\u6bcf\u9031 1 \u5c0f\u6642\u500b\u5225\u6307\u5c0e\u3002\u8001\u5e2b\u771f\u7684\u4e86\u89e3\u6bcf\u4f4d\u5b78\u751f\u7684\u72c0\u6cc1\u3002</p> <p>\u56db\u7d1a\u74b0\u74b0\u76f8\u6263\uff0c\u5f9e\u300c\u80fd\u8dd1\u51fa\u6a21\u64ec\u7d50\u679c\u300d\u5230\u300c\u80fd\u5beb\u7814\u7a76\u5831\u544a\u300d\uff0c\u6bcf\u4e00\u6b65\u90fd\u6709\u660e\u78ba\u91cc\u7a0b\u7891\u3002</p>"},{"location":"#_4","title":"\u8ab2\u7a0b\u898f\u683c","text":"\u9805\u76ee \u898f\u683c \u6bcf\u7d1a\u9577\u5ea6 10 \u9031 \u4e0a\u8ab2\u5f62\u5f0f \u6bcf\u9031 2 \u5c0f\u6642\u5c0f\u73ed + 1 \u5c0f\u6642\u500b\u5225\u6307\u5c0e \u6bcf\u7d1a\u7e3d\u6642\u6578 \u7d04 30 \u5c0f\u6642 \u5efa\u8b70\u73ed\u7d1a\u4eba\u6578 4\u20138 \u4eba \u7a0b\u5f0f\u8a9e\u8a00 Python 3\uff08Level 1 \u8d77\u9700\u5177\u5099\u57fa\u790e\u8a9e\u6cd5\u80fd\u529b\uff09 <p>\u67e5\u770b\u8ab2\u7a0b\u4ecb\u7d39 \u2192 \u67e5\u770b\u5b9a\u50f9\u65b9\u6848 \u2192</p>"},{"location":"faq/","title":"\u5e38\u898b\u554f\u984c FAQ","text":""},{"location":"faq/#_1","title":"\u8ab2\u7a0b\u5b9a\u4f4d","text":"<p>Q\uff1a\u9019\u662f APCS \u8ab2\u7a0b\u55ce\uff1f\u8ddf\u8a9e\u6cd5\u8ab2\u6709\u4ec0\u9ebc\u5dee\u5225\uff1f</p> <p>\u4e0d\u662f\u3002\u672c\u8ab2\u7a0b\u4e0d\u6559 APCS \u8003\u8a66\uff0c\u4e5f\u4e0d\u4ee5\u5237\u984c\u70ba\u76ee\u7684\u3002\u91cd\u9ede\u662f\u7528 Python \u505a\u6a21\u64ec\u3001\u5efa\u6a21\u8207\u7814\u7a76\uff0c\u6700\u7d42\u7522\u51fa\u662f\u4e00\u4efd\u5b78\u751f\u81ea\u5df1\u5b8c\u6210\u7684\u5c08\u984c\u5831\u544a\u6216\u7814\u7a76\u7a3f\uff0c\u4e0d\u662f\u8003\u8a66\u6210\u7e3e\u3002</p> <p>\u9069\u5408\u5df2\u6709 Python \u57fa\u790e\uff08\u4e0a\u5b8c\u8a9e\u6cd5\u73ed\uff09\u3001\u60f3\u505a\u51fa\u4e00\u500b\u300c\u8aaa\u5f97\u51fa\u4f86\u3001\u7528\u5f97\u4e0a\u300d\u6210\u679c\u7684\u5b78\u751f\u3002</p> <p>Q\uff1a\u8ddf\u5916\u9762\u7684\u300c\u5c08\u984c\u71df\u968a\u300d\u6709\u4ec0\u9ebc\u4e0d\u540c\uff1f</p> \u4e00\u822c\u5c08\u984c\u71df\u968a \u672c\u8ab2\u7a0b \u6642\u9577 2\u20134 \u9031\u5bc6\u96c6 10 \u9031\uff0c\u6bcf\u9031\u56fa\u5b9a \u500b\u5225\u6307\u5c0e \u901a\u5e38\u7121 \u6bcf\u9031 1 \u5c0f\u6642 1-on-1 \u6210\u679c \u8ddf\u8457\u6a21\u677f\u505a \u5b78\u751f\u81ea\u5df1\u7684\u984c\u76ee\u8207\u7814\u7a76\u554f\u984c \u53ef\u7528\u65bc\u7533\u8acb \u4e0d\u4e00\u5b9a Level 2 \u4ee5\u4e0a\u53ef\u5c0d\u63a5 AP/IB/A-Level \u8a55\u5206"},{"location":"faq/#_2","title":"\u5165\u73ed\u689d\u4ef6","text":"<p>Q\uff1a\u6211\u7684\u5b69\u5b50\u9700\u8981\u4ec0\u9ebc\u7a0b\u5ea6\u624d\u80fd\u4e0a Level 1\uff1f</p> <p>\u5177\u5099\u4ee5\u4e0b\u57fa\u790e\u5373\u53ef\uff1a - \u6703\u5beb Python \u7684\u8b8a\u6578\u3001\u8ff4\u5708\u3001\u51fd\u6578\uff08\u76f8\u7576\u65bc\u4e0a\u5b8c\u4e00\u9580 Python \u5165\u9580\u8ab2\uff09 - \u80fd\u5728\u81ea\u5df1\u96fb\u8166\u5b89\u88dd\u4e26\u57f7\u884c Python</p> <p>\u82e5\u5b69\u5b50\u5b8c\u5168\u6c92\u63a5\u89f8\u904e Python\uff0c\u5efa\u8b70\u5148\u5b8c\u6210\u5165\u9580\u8a9e\u6cd5\u8ab2\u7a0b\u518d\u4f86\u5831\u540d\u3002</p> <p>Q\uff1a\u53ef\u4ee5\u76f4\u63a5\u5831\u540d Level 2 \u6216\u66f4\u9ad8\u55ce\uff1f</p> <p>\u53ef\u4ee5\uff0c\u4f46\u9700\u8981\u5148\u901a\u904e\u7a0b\u5ea6\u6e2c\u9a57\uff08\u7d04 30 \u5206\u9418\u7dda\u4e0a\u6e2c\u9a57\uff09\u3002\u6e2c\u9a57\u7d50\u679c\u6c7a\u5b9a\u9069\u5408\u7684\u5165\u73ed Level\uff0c\u7d50\u679c 3 \u500b\u5de5\u4f5c\u5929\u5167\u901a\u77e5\u3002</p> <p>Q\uff1a\u5347\u5b78\u8003\u8a66\u5f88\u5fd9\uff0c\u53ef\u4ee5\u540c\u6642\u61c9\u4ed8\u8ab2\u696d\u55ce\uff1f</p> <p>\u6bcf\u9031\u7d04 3 \u5c0f\u6642\u4e0a\u8ab2 + 1\u20133 \u5c0f\u6642\u4f5c\u696d\u3002\u9047\u6bb5\u8003\u9031\uff0c\u4f5c\u696d\u91cf\u6703\u6e1b\u534a\u3002\u5c0d\u6709\u6642\u9593\u7ba1\u7406\u7fd2\u6163\u7684\u5b78\u751f\uff0c\u9019\u500b\u7bc0\u594f\u662f\u53ef\u8ca0\u64d4\u7684\u3002</p>"},{"location":"faq/#_3","title":"\u8ab2\u7a0b\u5167\u5bb9","text":"<p>Q\uff1a\u56db\u500b Level \u5206\u5225\u5728\u5b78\u4ec0\u9ebc\uff1f</p> Level \u540d\u7a31 \u4e3b\u8981\u5b78\u4ec0\u9ebc \u7522\u51fa 1 \u6a21\u64ec\u5165\u9580 \u9ab0\u5b50\u3001\u6392\u968a\u3001\u6210\u9577\u6a21\u578b\u3001\u96a8\u6a5f\u6a21\u64ec \u5c0f\u578b\u6a21\u64ec\u5c08\u984c\u5831\u544a 2 AP/IB/A-Level \u5c08\u984c \u5b8c\u6574\u5c08\u984c\u8a2d\u8a08\u3001\u8cc7\u6599\u5206\u6790\u3001\u5831\u544a\u5beb\u4f5c \u5b8c\u6574\u7814\u7a76\u5831\u544a\uff08\u53ef\u7528\u65bc AP/IB\uff09 3 \u6578\u503c\u65b9\u6cd5\u8207\u512a\u5316 NumPy\u3001SciPy\u3001\u6700\u4f73\u5316\u65b9\u6cd5 \u6578\u503c\u6a21\u578b\u5c08\u984c + \u6280\u8853\u5831\u544a 4 Research / Capstone \u6587\u737b\u63a2\u8a0e\u3001\u7814\u7a76\u5beb\u4f5c\u3001\u6a21\u64ec\u53e3\u8a66 \u63a5\u8fd1\u5927\u5b78 capstone \u7b49\u7d1a\u7684\u7814\u7a76\u5831\u544a <p>Q\uff1aLevel 2 \u7684\u6210\u679c\u771f\u7684\u53ef\u4ee5\u7528\u65bc AP Research / IB IA \u55ce\uff1f</p> <p>\u53ef\u4ee5\u4f5c\u70ba\u7d20\u6750\u8207\u57fa\u790e\u3002Level 2 \u7684\u8ab2\u7a0b\u8a2d\u8a08\u5c0d\u9f4a AP Research \u548c IB IA \u7684\u8a55\u5206\u67b6\u69cb\uff08\u7814\u7a76\u554f\u984c\u3001\u65b9\u6cd5\u3001\u7d50\u679c\u3001\u8a0e\u8ad6\uff09\uff0c\u5b78\u751f\u5b8c\u6210\u7684\u5831\u544a\u7b26\u5408\u9019\u4e9b\u8ab2\u7a0b\u7684\u8981\u6c42\u683c\u5f0f\u3002\u6700\u7d42\u63d0\u4ea4\u7248\u672c\u4ecd\u9700\u7b26\u5408\u5404\u6821\u898f\u5b9a\uff0c\u5efa\u8b70\u8207\u5b78\u6821\u8001\u5e2b\u78ba\u8a8d\u3002</p> <p>Q\uff1a\u4e0a\u8ab2\u6703\u7528\u4e2d\u6587\u9084\u662f\u82f1\u6587\uff1f</p> <p>Level 1\u20132 \u4ee5\u4e2d\u6587\u70ba\u4e3b\uff0c\u82f1\u6587\u8853\u8a9e\u6703\u4fdd\u7559\u4e26\u8aaa\u660e\u3002Level 3\u20134 \u53ef\u4f9d\u5b78\u751f\u9700\u6c42\u5207\u63db\u81f3\u4e2d\u82f1\u6df7\u5408\u6216\u5168\u82f1\u6587\uff08\u5982\u570b\u969b\u5b78\u6821\u5b78\u751f\uff09\u3002</p>"},{"location":"faq/#_4","title":"\u4e0a\u8ab2\u6a21\u5f0f","text":"<p>Q\uff1a\u6bcf\u9031\u9700\u8981\u4e0a\u5e7e\u500b\u5c0f\u6642\uff1f</p> <ul> <li>Group \u8ab2\uff08\u5c0f\u73ed\uff0c4\u20138 \u4eba\uff09\uff1a\u6bcf\u9031 2 \u5c0f\u6642\uff0c\u5168\u73ed\u56fa\u5b9a\u6642\u6bb5</li> <li>1-on-1 \u500b\u5225\u6307\u5c0e\uff1a\u6bcf\u9031 1 \u5c0f\u6642\uff0c\u8207\u8001\u5e2b\u55ae\u7368\u8a0e\u8ad6\uff08\u7368\u7acb\u6392\u5b9a\u6642\u6bb5\uff09</li> </ul> <p>Q\uff1a\u4e00\u73ed\u6709\u591a\u5c11\u4eba\uff1f</p> <p>\u5efa\u8b70\u73ed\u7d1a\u4eba\u6578 4\u20138 \u4eba\u3002\u4f4e\u65bc 3 \u4eba\u4e0d\u958b\u73ed\uff1b\u8d85\u904e 8 \u4eba\u5efa\u8b70\u958b\u7b2c\u4e8c\u73ed\u3002</p> <p>Q\uff1a\u662f\u5be6\u9ad4\u8ab2\u9084\u662f\u7dda\u4e0a\u8ab2\uff1f</p> <p>\u4e3b\u8981\u70ba\u5be6\u9ad4\u8ab2\uff08\u65bc\u5408\u4f5c\u88dc\u7fd2\u73ed\u6559\u5ba4\uff09\u3002\u82e5\u56e0\u7279\u6b8a\u60c5\u6cc1\u7121\u6cd5\u5be6\u9ad4\uff0c\u6539\u70ba\u7dda\u4e0a\uff08Google Meet / Zoom\uff09\uff0c\u8ab2\u7a0b\u7d50\u69cb\u4e0d\u8b8a\u3002</p> <p>Q\uff1a\u53ef\u4ee5\u9304\u5f71\u55ce\uff1f\u6709\u88dc\u8ab2\u9304\u5f71\u55ce\uff1f</p> <p>Group \u8ab2\u6709\u9304\u5f71\uff0c\u7f3a\u5e2d\u5b78\u751f\u53ef\u65bc 48 \u5c0f\u6642\u5167\u88dc\u770b\u3002\u9304\u5f71\u50c5\u4f9b\u672c\u4eba\u4f7f\u7528\uff0c\u4fdd\u5b58\u671f\u9650\u81f3\u8ab2\u7a0b\u7d50\u675f\u5f8c 30 \u5929\u3002</p>"},{"location":"faq/#_5","title":"\u8cbb\u7528\u8207\u9000\u8cbb","text":"<p>Q\uff1a\u8cbb\u7528\u662f\u591a\u5c11\uff1f</p> Level \u5b9a\u50f9 Level 1\u20133 30,000 \u5143 / \u7d1a Level 4 34,000 \u5143 / \u7d1a <p>\u6bcf\u5c0f\u6642\u7b49\u6548\u8cbb\u7528\u7d04 1,000\u20131,133 \u5143\uff08\u542b group + 1-on-1\uff09\u3002</p> <p>Q\uff1a\u6709\u65e9\u9ce5\u512a\u60e0\u55ce\uff1f</p> <p>\u6709\uff0c\u65e9\u9ce5\u5831\u540d\u4eab 88 \u6298\uff08Level 1\u20133 \u7d04 26,400 \u5143\uff1bLevel 4 \u7d04 29,920 \u5143\uff09\u3002\u512a\u60e0\u8a73\u60c5\u8acb\u6d3d\u62db\u751f\u7a97\u53e3\uff0c\u512a\u60e0\u64c7\u4e00\u4e0d\u4f75\u7528\u3002</p> <p>Q\uff1a\u5982\u679c\u4e0a\u5230\u4e00\u534a\u60f3\u9000\u8cbb\u53ef\u4ee5\u55ce\uff1f</p> <p>\u53ef\u4ee5\uff0c\u4f9d\u5df2\u4e0a\u9031\u6578\u8a08\u7b97\u9000\u8cbb\u6bd4\u4f8b\uff1a</p> <ul> <li>\u958b\u8ab2\u524d\uff1a\u5168\u984d\u9000\u8cbb\uff08\u6263 500 \u5143\u884c\u653f\u8cbb\uff09</li> <li>\u7b2c 1 \u9031\u5f8c\uff1a\u9000 90%\uff0c\u4f9d\u6b64\u985e\u63a8</li> <li>\u7b2c 8 \u9031\u5f8c\uff1a\u4e0d\u9000\u8cbb</li> </ul>"},{"location":"faq/#_6","title":"\u6210\u679c\u61c9\u7528","text":"<p>Q\uff1a\u5b69\u5b50\u5b8c\u8ab2\u5f8c\u6703\u6709\u4ec0\u9ebc\u53ef\u4ee5\u7528\u7684\u6771\u897f\uff1f</p> <p>\u6bcf\u4e00\u7d1a\u90fd\u6709\u5177\u9ad4\u7522\u51fa\uff1a</p> <ul> <li>Level 1\uff1a\u5c0f\u578b\u6a21\u64ec\u5c08\u984c\u5831\u544a\uff08portfolio \u8d77\u9ede\uff09</li> <li>Level 2\uff1a\u5b8c\u6574\u7814\u7a76\u578b\u5831\u544a\uff08\u53ef\u5c0d\u63a5 AP Research / IB IA \u683c\u5f0f\uff09</li> <li>Level 3\uff1a\u542b\u6578\u503c\u65b9\u6cd5\u8207\u6700\u4f73\u5316\u7684\u6280\u8853\u5831\u544a</li> <li>Level 4\uff1a\u7814\u7a76\u5831\u544a\u8349\u7a3f\uff08\u53ef\u7528\u65bc\u5927\u5b78\u7533\u8acb portfolio \u6216\u7af6\u8cfd\uff09</li> </ul> <p>Q\uff1a\u53ef\u4ee5\u7528\u5728\u5927\u5b78\u7533\u8acb\u55ce\uff1f</p> <p>Level 2 \u4ee5\u4e0a\u7684\u6210\u679c\u53ef\u4ee5\u5beb\u9032\u5927\u5b78\u7533\u8acb\u7684 activity list\u3001additional info\uff0c\u6216\u4f5c\u70ba writing sample \u7d20\u6750\u3002Level 4 \u7684\u7814\u7a76\u5831\u544a\u683c\u5f0f\u63a5\u8fd1\u5927\u5b78 capstone\uff0c\u5177\u6709\u7533\u8acb\u8aaa\u660e\u50f9\u503c\u3002</p> <p>Q\uff1a\u6c92\u6709\u8981\u7533\u8acb\u7f8e\u570b\u5927\u5b78\uff0c\u9019\u500b\u8ab2\u7a0b\u9069\u5408\u55ce\uff1f</p> <p>\u9069\u5408\u3002\u8ab2\u7a0b\u7684\u6838\u5fc3\u662f\u57f9\u990a\u300c\u7528 Python \u89e3\u6c7a\u771f\u5be6\u554f\u984c\u7684\u80fd\u529b\u300d\uff0c\u5728\u53f0\u7063\u5927\u5b78\u7533\u8acb\u3001\u79d1\u5c55\u3001\u6578\u6a21\u7af6\u8cfd\u3001STEM \u7814\u7a76\u793e\u5718\u90fd\u6709\u76f4\u63a5\u61c9\u7528\u50f9\u503c\u3002</p>"},{"location":"partner/","title":"\u88dc\u7fd2\u73ed\u5408\u4f5c\u65b9\u6848","text":"<p>\u672c\u8ab2\u7a0b\u70ba\u300cPython \u8a9e\u6cd5\u73ed\u300d\u7684\u81ea\u7136\u4e0b\u4e00\u6b65\u3002\u6211\u5011\u5354\u52a9\u88dc\u7fd2\u73ed\u7559\u4f4f\u5df2\u5b78\u5b8c\u8a9e\u6cd5\u7684\u5b78\u751f\uff0c\u540c\u6642\u958b\u51fa\u73fe\u6709\u7522\u54c1\u7dda\u4e2d\u6c92\u6709\u7684\u9ad8\u55ae\u50f9\u9032\u968e\u8ab2\u7a0b\u3002</p>"},{"location":"partner/#_2","title":"\u5408\u4f5c\u6a21\u5f0f","text":""},{"location":"partner/#a-6040","title":"\u65b9\u6848 A\uff1a\u88dc\u7fd2\u73ed\u5168\u8cac\u62db\u751f\uff08\u5206\u6f64 60/40\uff09","text":"<p>\u88dc\u7fd2\u73ed\u8ca0\u8cac\u62db\u751f\u3001\u884c\u653f\u3001\u6559\u5ba4\uff1b\u8ab2\u7a0b\u65b9\u8ca0\u8cac\u5168\u90e8\u6559\u5b78\u5167\u5bb9\u8207\u54c1\u8cea\u3002</p> \u9805\u76ee \u8aaa\u660e \u88dc\u7fd2\u73ed\u6536\u76ca \u5b78\u8cbb 40% \u8ab2\u7a0b\u65b9\u6536\u76ca \u5b78\u8cbb 60% \u88dc\u7fd2\u73ed\u8ca0\u8cac \u62db\u751f\u5ba3\u50b3\u3001\u884c\u653f\u5831\u540d\u3001\u5834\u5730\u63d0\u4f9b \u8ab2\u7a0b\u65b9\u8ca0\u8cac \u8ab2\u7db1\u3001\u8b1b\u7fa9\u3001\u6559\u5b78\u30011-on-1\u3001\u5bb6\u9577\u9032\u5ea6\u56de\u5831 \u958b\u73ed\u9580\u6abb \u6700\u5c11 3 \u4eba\u958b\u73ed\uff0c\u5efa\u8b70 4\u20138 \u4eba <p>\u8a66\u7b97\uff08Level 1\uff0c30,000 \u5143 \u00d7 6 \u4eba\u73ed\uff09\uff1a</p> \u7121\u6298\u6263 \u65e9\u9ce5 88 \u6298 \u7e3d\u71df\u6536 180,000 \u5143 158,400 \u5143 \u88dc\u7fd2\u73ed\u6536\u76ca 72,000 \u5143 63,360 \u5143 \u8ab2\u7a0b\u65b9\u6536\u76ca 108,000 \u5143 95,040 \u5143"},{"location":"partner/#b-7030","title":"\u65b9\u6848 B\uff1a\u96d9\u908a\u62db\u751f\uff08\u5206\u6f64 70/30\uff09","text":"<p>\u82e5\u8ab2\u7a0b\u65b9\u4e5f\u5354\u52a9\u5e36\u5b78\u751f\u9032\u5165\uff08\u63a8\u85a6\u5b78\u751f\u3001\u806f\u5408\u884c\u92b7\uff09\uff0c\u5206\u6f64\u8abf\u6574\u70ba 7:3\u3002</p> \u9805\u76ee \u8aaa\u660e \u88dc\u7fd2\u73ed\u6536\u76ca \u5b78\u8cbb 30% \u8ab2\u7a0b\u65b9\u6536\u76ca \u5b78\u8cbb 70% \u9069\u7528\u689d\u4ef6 \u8ab2\u7a0b\u65b9\u4e5f\u4e3b\u52d5\u5e36\u5b78\u751f\u3001\u5354\u52a9\u62db\u751f"},{"location":"partner/#_3","title":"\u88dc\u7fd2\u73ed\u7684\u6536\u76ca","text":""},{"location":"partner/#_4","title":"\u6bcf\u73ed\u6536\u5165\u4f30\u7b97","text":"\u73ed\u7d1a\u4eba\u6578 Level 1\u20133\uff0830,000/\u4eba\uff09 Level 4\uff0834,000/\u4eba\uff09 4 \u4eba\u73ed 48,000 \u5143\uff08\u65b9\u6848 A\uff09 54,400 \u5143 6 \u4eba\u73ed 72,000 \u5143\uff08\u65b9\u6848 A\uff09 81,600 \u5143 8 \u4eba\u73ed 96,000 \u5143\uff08\u65b9\u6848 A\uff09 108,800 \u5143 <p>\u6bcf\u958b\u4e00\u73ed\uff0c\u88dc\u7fd2\u73ed\u5373\u7372\u5f97\u4e0a\u8ff0\u91d1\u984d\uff0c\u7121\u9700\u6295\u5165\u4efb\u4f55\u6559\u5b78\u8cc7\u6e90\u3002</p>"},{"location":"partner/#_5","title":"\u70ba\u4ec0\u9ebc\u9069\u5408\u88dc\u7fd2\u73ed\uff1f","text":"<p>1. \u7559\u4f4f\u65e2\u6709\u5b78\u751f</p> <p>\u5b78\u5b8c Python \u8a9e\u6cd5\u7684\u5b78\u751f\uff0c\u4e0b\u4e00\u6b65\u901a\u5e38\u662f\u53bb\u5916\u9762\u7684\u5c08\u984c\u71df\u968a\u3002\u9019\u500b\u8ab2\u7a0b\u8b93\u4ed6\u5011\u7559\u5728\u4f60\u5011\u9ad4\u7cfb\u88e1\uff0c\u7e7c\u7e8c\u5347\u9032\u968e\u73ed\u3002</p> <p>2. \u88dc\u9f4a\u9ad8\u55ae\u50f9\u7522\u54c1\u7dda</p> <p>\u5e02\u5834\u4e0a\u5e7e\u4e4e\u6c92\u6709\u300cPython \u5efa\u6a21 + \u500b\u5225\u6307\u5c0e + \u7814\u7a76\u5831\u544a\u300d\u7684\u8ab2\u7a0b\u3002\u9019\u662f\u4e00\u500b\u4f60\u5011\u73fe\u6709\u7522\u54c1\u7dda\u6c92\u6709\u7684\u7a7a\u7f3a\u3002</p> <p>3. \u5b78\u8cbb\u9ad8\u3001\u5bb6\u9577\u63a5\u53d7\u5ea6\u4f73</p> <p>30,000 \u5143 / 10 \u9031\uff0c\u6bcf\u5c0f\u6642\u7d04 1,000 \u5143\uff08\u542b group + 1-on-1\uff09\u3002\u5c0d\u6709\u7533\u8acb\u9700\u6c42\u7684\u5bb6\u9577\uff0cCP \u503c\u660e\u78ba\uff0c\u8aaa\u670d\u5bb9\u6613\u3002</p> <p>4. \u4f60\u53ea\u9700\u8981\u62db\u751f\uff0c\u6211\u5011\u8ca0\u8cac\u6559\u5b78</p> <p>\u8ab2\u7db1\u3001\u8b1b\u7fa9\u3001\u4f5c\u696d\u8a2d\u8a08\u3001\u5bb6\u9577\u9032\u5ea6\u56de\u5831\u3001\u8a55\u5206\u5168\u90e8\u7531\u8ab2\u7a0b\u65b9\u8655\u7406\u3002\u62db\u751f\u7528\u4f60\u5011\u73fe\u6709\u7684\u65e9\u9ce5/\u5718\u5831/\u7279\u7d04\u6298\u6263\u898f\u5247\u5373\u53ef\u3002</p>"},{"location":"partner/#_6","title":"\u5408\u4f5c\u898f\u683c\u4e00\u89bd","text":"\u9805\u76ee \u8aaa\u660e \u6298\u6263\u898f\u5247 \u6cbf\u7528\u88dc\u7fd2\u73ed\u73fe\u6709\u65e9\u9ce5/\u5718\u5831/\u7279\u7d04\u6298\u6263\uff0888 \u6298 / 9 \u6298\uff09 \u884c\u653f\u7cfb\u7d71 \u4f7f\u7528\u88dc\u7fd2\u73ed\u73fe\u6709\u5831\u540d\u8207\u6536\u8cbb\u7cfb\u7d71 \u6559\u5ba4 \u88dc\u7fd2\u73ed\u63d0\u4f9b\uff0c\u6bcf\u9031 group \u8ab2 2 \u5c0f\u6642 \u5206\u6f64\u6e05\u7b97 \u6bcf\u73ed\u8ab2\u7a0b\u7d50\u675f\u5f8c\u6e05\u7b97\u4e00\u6b21 \u5e2b\u8cc7 \u8ab2\u7a0b\u65b9\u5168\u8cac\uff0c\u88dc\u7fd2\u73ed\u7121\u9700\u53e6\u627e\u8001\u5e2b"},{"location":"partner/#_7","title":"\u9069\u5408\u5408\u4f5c\u7684\u88dc\u7fd2\u73ed\u985e\u578b","text":"<ul> <li>\u5df2\u6709 Python / APCS / C++ \u73ed\u7684\u88dc\u7fd2\u73ed\uff0c\u60f3\u589e\u52a0\u9032\u968e\u8def\u5f91</li> <li>\u6709\u570b\u969b\u5b78\u6821\u3001\u96d9\u8a9e\u5b78\u6821\u5b78\u751f\u7684\u5347\u5b78\u88dc\u7fd2\u73ed</li> <li>\u6709 STEM \u73ed\u5e95\u3001\u60f3\u62d3\u5c55\u9ad8\u55ae\u50f9\u8ab2\u7a0b\u7684\u88dc\u7fd2\u73ed</li> </ul>"},{"location":"partner/#_8","title":"\u806f\u7d61\u6d3d\u8ac7","text":"<p>\u6709\u8208\u8da3\u4e86\u89e3\u5408\u4f5c\u7d30\u7bc0\uff0c\u6b61\u8fce\u806f\u7d61\uff1a</p> <ul> <li>\u53ef\u63d0\u4f9b\u5b8c\u6574\u8ab2\u7a0b\u8aaa\u660e\u6587\u4ef6\uff08\u8ab2\u7db1\u3001\u5b9a\u50f9\u3001\u5206\u6f64\u8a66\u7b97\uff09</li> <li>\u53ef\u5b89\u6392 30 \u5206\u9418\u7dda\u4e0a\u8aaa\u660e\u6703</li> <li>\u53ef\u63d0\u4f9b\u8a66\u8fa6\u4e00\u73ed\u65b9\u6848\uff08Level 1 \u6691\u671f\u73ed\uff09</li> </ul> <p>\u8a66\u8fa6\u4e00\u73ed\u98a8\u96aa\u6700\u4f4e\uff0c\u8b93\u96d9\u65b9\u90fd\u53ef\u4ee5\u78ba\u8a8d\u5408\u4f5c\u7bc0\u594f\u3002</p>"},{"location":"pricing/","title":"\u5b9a\u50f9\u8207\u512a\u60e0","text":""},{"location":"pricing/#_2","title":"\u8ab2\u7a0b\u5b9a\u50f9","text":"Level \u8ab2\u7a0b\u540d\u7a31 \u5b9a\u50f9\uff08TWD\uff09 \u7e3d\u6642\u6578 Level 1 \u6a21\u64ec\u5165\u9580 NT$30,000 30 \u5c0f\u6642 Level 2 AP/IB \u5c08\u984c NT$30,000 30 \u5c0f\u6642 Level 3 \u6578\u503c\u65b9\u6cd5\u8207\u512a\u5316 NT$30,000 30 \u5c0f\u6642 Level 4 Research Capstone NT$34,000 30 \u5c0f\u6642 <p>\u6bcf\u7d1a 30 \u5c0f\u6642 = \u6bcf\u9031 2 \u5c0f\u6642\u5c0f\u73ed + \u6bcf\u4eba\u6bcf\u9031 1 \u5c0f\u6642\u500b\u5225\u6307\u5c0e \u00d7 10 \u9031</p>"},{"location":"pricing/#_3","title":"\u6bcf\u5c0f\u6642\u7b49\u6548\u6210\u672c","text":"Level 1\u20133 Level 4 \u6bcf\u5c0f\u6642\u8cbb\u7528 \u7d04 NT$1,000 \u7d04 NT$1,133 \u5c0d\u6bd4\u5bb6\u6559\u5e02\u5834 \u542b\u5c0f\u73ed + 1-on-1\uff0c\u76f8\u7576\u5212\u7b97 \u542b\u6587\u737b\u6307\u5c0e + \u53e3\u8a66\u6a21\u64ec"},{"location":"pricing/#_4","title":"\u512a\u60e0\u65b9\u6848","text":"\u512a\u60e0\u985e\u578b \u689d\u4ef6 \u6298\u6263 \u65e9\u9ce5\u512a\u60e0 \u6307\u5b9a\u65e5\u671f\u524d\u5831\u540d 88 \u6298 \u591a\u4eba\u5718\u5831 3 \u4eba\u4ee5\u4e0a\u540c\u6642\u5831\u540d\u540c\u4e00\u7d1a 88 \u6298 \u591a\u7d1a\u512a\u60e0 \u540c\u4e00\u4eba\u540c\u6642\u5831\u540d 2 \u7d1a\u4ee5\u4e0a 88 \u6298 \u7e8c\u73ed\u512a\u60e0 \u76f4\u63a5\u5831\u540d\u4e0b\u4e00\u7d1a\u7684\u5728\u8b80\u5b78\u751f 9 \u6298 \u7279\u7d04\u512a\u60e0 \u7279\u7d04\u5b78\u6821\uff0f\u5408\u4f5c\u6a5f\u69cb\u5b78\u751f 9 \u6298 <p>\u512a\u60e0\u64c7\u4e00\u4f7f\u7528\uff0c\u4e0d\u4f75\u7528\u3002</p>"},{"location":"pricing/#_5","title":"\u8cbb\u7528\u5305\u542b","text":"<ul> <li>\u6bcf\u9031 2 \u5c0f\u6642\u5c0f\u73ed\u8ab2\uff084\u20138 \u4eba\uff09</li> <li>\u6bcf\u4eba\u6bcf\u9031 1 \u5c0f\u6642\u500b\u5225\u6307\u5c0e\uff081-on-1\uff09</li> <li>\u6bcf\u9031\u8ab2\u7a0b\u6750\u6599\u8207\u4f5c\u696d\u8aaa\u660e\uff08PDF\uff09</li> <li>\u8001\u5e2b\u6279\u6539\u4f5c\u696d\u8207\u66f8\u9762\u56de\u994b</li> <li>\u671f\u672b\u6210\u679c\u7522\u51fa\uff08\u5831\u544a + \u7c21\u5831 + \u7a0b\u5f0f\u78bc\uff09</li> </ul>"},{"location":"pricing/#_6","title":"\u5e38\u898b\u554f\u984c","text":"<p>Q\uff1a\u8df3\u904e Level 1 \u53ef\u4ee5\u76f4\u63a5\u5b78 Level 2 \u55ce\uff1f A\uff1a\u53ef\u4ee5\u3002\u6211\u5011\u6703\u505a\u7c21\u55ae\u7684\u7a0b\u5ea6\u8a55\u4f30\uff0c\u78ba\u8a8d\u4f60\u5177\u5099 Python \u57fa\u790e\uff08\u8ff4\u5708\u3001\u51fd\u5f0f\u3001list\uff09\u5f8c\u5373\u53ef\u5831\u540d Level 2\u3002</p> <p>Q\uff1a\u53ef\u4ee5\u53ea\u4e0a\u4e00\u7d1a\u55ce\uff1f\u4e0d\u9700\u8981\u628a\u56db\u7d1a\u90fd\u5b78\u5b8c\uff1f A\uff1a\u53ef\u4ee5\u3002\u6bcf\u4e00\u7d1a\u90fd\u6709\u7368\u7acb\u5b8c\u6574\u7684\u6210\u679c\uff0c\u5b78\u751f\u53ef\u4ee5\u6839\u64da\u9700\u6c42\u9078\u64c7\u8981\u8d70\u5230\u54ea\u4e00\u7d1a\u3002</p> <p>Q\uff1a\u4e0a\u8ab2\u5f62\u5f0f\u662f\u7dda\u4e0a\u9084\u662f\u5be6\u9ad4\uff1f A\uff1a\u4ee5\u5c0f\u73ed\u5be6\u9ad4\u8ab2\u70ba\u4e3b\uff1b\u6709\u9700\u6c42\u7684\u5b78\u751f\u53ef\u4ee5\u5b89\u6392\u9060\u7aef\u4e0a\u8ab2\uff08\u8996\u5730\u9ede\u800c\u5b9a\uff09\u3002</p> <p>\u67e5\u770b\u5408\u4f5c\u65b9\u6848 \u2192</p>"},{"location":"courses/level-1/","title":"Level 1\uff1a\u6a21\u64ec\u5165\u9580","text":"<p>\u7528 Python \u8dd1\u771f\u5be6\u7684\u96a8\u6a5f\u6a21\u64ec\uff0c\u7b2c\u4e00\u6b21\u5c31\u7522\u51fa\u6709\u610f\u7fa9\u7684\u7d50\u679c</p>"},{"location":"courses/level-1/#_1","title":"\u8ab2\u7a0b\u76ee\u6a19","text":"<p>\u5b8c\u6210 Level 1 \u7684\u5b78\u751f\u80fd\u5920\uff1a</p> <ul> <li>\u7528 Python \u5efa\u7acb\u96a8\u6a5f\u6a21\u64ec\u6a21\u578b\uff08\u9ab0\u5b50\u3001\u968a\u4f0d\u3001\u75ab\u60c5\u64f4\u6563\uff09</li> <li>\u7528\u5716\u8868\u5448\u73fe\u6a21\u64ec\u7d50\u679c\u4e26\u8aaa\u660e\u610f\u7fa9</li> <li>\u7368\u7acb\u5b8c\u6210\u4e00\u4efd mini project\uff0c\u5305\u542b\u7a0b\u5f0f\u78bc + \u5206\u6790\u8aaa\u660e</li> <li>\u990a\u6210\u300c\u5148\u5efa\u6a21\u3001\u518d\u8dd1\u6a21\u64ec\u3001\u518d\u5206\u6790\u300d\u7684\u601d\u8003\u7fd2\u6163</li> </ul>"},{"location":"courses/level-1/#_2","title":"\u9069\u5408\u5c0d\u8c61","text":"<ul> <li>\u5df2\u6709\u57fa\u790e Python \u80fd\u529b\uff08\u6703\u8ff4\u5708\u3001\u51fd\u6578\u3001list\uff09\uff0c\u60f3\u628a\u7a0b\u5f0f\u7528\u5728\u771f\u5be6\u554f\u984c\u4e0a</li> <li>\u5c0d\u6578\u5b78\u6216\u79d1\u5b78\u6709\u8208\u8da3\uff0c\u4f46\u4e0d\u78ba\u5b9a\u8981\u505a\u4ec0\u9ebc\u5c08\u984c</li> <li>\u60f3\u70ba AP/IB/\u5b78\u7fd2\u6b77\u7a0b\u6e96\u5099\uff0c\u9700\u8981\u4e00\u500b\u8d77\u9ede</li> <li>APCS \u8003\u5b8c\u3001\u60f3\u627e\u300c\u4e0b\u4e00\u6b65\u300d\u7684\u5b78\u751f</li> </ul> <p>\u5148\u4fee\u8981\u6c42\uff1aPython \u57fa\u790e\uff08\u8b8a\u6578\u3001\u8ff4\u5708\u3001\u51fd\u6578\uff09\u3002\u5b8c\u5168\u96f6\u57fa\u790e\u8005\u5efa\u8b70\u5148\u5b8c\u6210 Python \u5165\u9580\u8ab2\u7a0b\u3002</p>"},{"location":"courses/level-1/#10","title":"10 \u9031\u8ab2\u7a0b\u5927\u7db1","text":"\u9031\u6b21 \u4e3b\u984c \u6838\u5fc3\u6280\u80fd \u7b2c 1 \u9031 \u4ec0\u9ebc\u662f\u6a21\u64ec\uff1f\u9ab0\u5b50\u5be6\u9a57 <code>random</code>\u3001\u57fa\u672c\u8ff4\u5708\u3001<code>matplotlib</code> \u7b2c 2 \u9031 \u6a5f\u7387\u904a\u6232\uff1a\u5f69\u7968\u8207\u751f\u65e5\u6096\u8ad6 \u5927\u6578\u6cd5\u5247\u3001\u76f4\u65b9\u5716 \u7b2c 3 \u9031 \u6392\u968a\u7cfb\u7d71\uff1a\u7b49\u5f85\u6642\u9593\u6a21\u64ec \u591a\u8b8a\u6578\u6a21\u578b\u3001\u53c3\u6578\u8abf\u6574 \u7b2c 4 \u9031 \u6210\u9577\u8207\u8870\u9000\uff1a\u5dee\u5206\u6a21\u578b SIR \u6a21\u578b\u3001\u6307\u6578\u6210\u9577\u3001\u6298\u7dda\u5716 \u7b2c 5 \u9031 \u5c0f\u5c08\u984c 1\uff1a\u500b\u4eba mini project \u7368\u7acb\u5efa\u6a21\u3001\u554f\u984c\u5b9a\u7fa9 \u7b2c 6 \u9031 \u8996\u89ba\u5316\uff1a\u7528\u5716\u8aaa\u6545\u4e8b <code>seaborn</code>\u3001\u591a\u5716\u6392\u7248\u3001\u5716\u8868\u6a19\u984c \u7b2c 7 \u9031 \u53c3\u6578\u8207\u654f\u611f\u5ea6 \u53c3\u6578\u6383\u63cf\u3001\u654f\u611f\u5ea6\u5206\u6790 \u7b2c 8 \u9031 \u5c0f\u7d44\u5c08\u984c\u5de5\u4f5c\u574a \u5354\u4f5c\u5206\u5de5\u3001\u7248\u672c\u7ba1\u7406 \u7b2c 9 \u9031 \u5c0f\u5831\u544a\u5beb\u4f5c\u7df4\u7fd2 \u7d50\u679c\u8a6e\u91cb\u3001\u5716\u6587\u6574\u5408 \u7b2c 10 \u9031 \u5c55\u793a\u8207\u53cd\u601d \u53e3\u982d\u8aaa\u660e\u3001Q&amp;A \u61c9\u7b54"},{"location":"courses/level-1/#_3","title":"\u671f\u672b\u6210\u679c","text":"<p>\u6bcf\u4f4d\u5b78\u751f\u5b8c\u6210\u4e00\u4efd Mini Project\uff0c\u5305\u542b\uff1a</p> <ul> <li>Python \u6a21\u64ec\u7a0b\u5f0f\u78bc\uff08\u53ef\u57f7\u884c\uff09</li> <li>1\u20132 \u9801\u5206\u6790\u8aaa\u660e\uff08\u554f\u984c \u2192 \u6a21\u578b \u2192 \u7d50\u679c \u2192 \u7d50\u8ad6\uff09</li> <li>2\u20133 \u5f35\u5716\u8868\uff08\u6e05\u695a\u6a19\u793a\u8ef8\u6a19\u984c\u8207\u89e3\u91cb\uff09</li> </ul>"},{"location":"courses/level-1/#_4","title":"\u8ab2\u7a0b\u898f\u683c","text":"\u9805\u76ee \u8aaa\u660e \u7d1a\u5225\u5b9a\u50f9 NT$30,000 \u8ab2\u7a0b\u9577\u5ea6 10 \u9031 \u6bcf\u9031\u4e0a\u8ab2 2 \u5c0f\u6642\u5c0f\u73ed\u8ab2 \u500b\u5225\u6307\u5c0e \u6bcf\u4eba\u6bcf\u9031 1 \u5c0f\u6642 1-on-1 \u7e3d\u6642\u6578 \u7d04 30 \u5c0f\u6642 <p>\u4e0b\u4e00\u7d1a\uff1aLevel 2 AP/IB \u5c08\u984c \u2192</p>"},{"location":"courses/level-2/","title":"Level 2\uff1aAP/IB \u5c08\u984c","text":"<p>\u7528\u6a21\u64ec\u8207\u6578\u64da\u5206\u6790\u5b8c\u6210\u4e00\u4efd\u771f\u6b63\u7684\u5b78\u8853\u5831\u544a</p>"},{"location":"courses/level-2/#_1","title":"\u8ab2\u7a0b\u76ee\u6a19","text":"<p>\u5b8c\u6210 Level 2 \u7684\u5b78\u751f\u80fd\u5920\uff1a</p> <ul> <li>\u5b9a\u7fa9\u4e00\u500b\u6709\u7814\u7a76\u50f9\u503c\u7684\u554f\u984c\uff08Research Question\uff09</li> <li>\u8a2d\u8a08\u4e26\u5be6\u4f5c\u5c0d\u61c9\u7684\u6a21\u64ec\u6216\u5206\u6790\u6a21\u578b</li> <li>\u64b0\u5beb\u7b26\u5408 AP/IB \u683c\u5f0f\u7684\u5b8c\u6574 project \u5831\u544a\uff086\u201310 \u9801\uff09</li> <li>\u88fd\u4f5c 10 \u5206\u9418\u53e3\u982d\u5831\u544a\u4e26\u56de\u7b54\u554f\u984c</li> </ul>"},{"location":"courses/level-2/#_2","title":"\u9069\u5408\u5c0d\u8c61","text":"<ul> <li>\u5b8c\u6210 Level 1 \u6216\u5177\u5099\u540c\u7b49 Python \u57fa\u790e</li> <li>\u6b63\u5728\u6e96\u5099 AP CS\u3001IB Math AA/AI\u3001A-Level \u7684 exploration/IA/EE</li> <li>\u9700\u8981\u4e00\u4efd\u5b8c\u6574 side project \u653e\u9032\u5927\u5b78\u7533\u8acb</li> </ul>"},{"location":"courses/level-2/#10","title":"10 \u9031\u8ab2\u7a0b\u5927\u7db1","text":"\u9031\u6b21 \u4e3b\u984c \u6838\u5fc3\u4efb\u52d9 \u7b2c 1 \u9031 \u8ab2\u7db1\u8207\u7bc4\u4f8b\u5c08\u984c\u62c6\u89e3 \u8a8d\u8b58\u597d\u7684 RQ \u662f\u4ec0\u9ebc \u7b2c 2 \u9031 \u6a21\u578b\u8207\u6a21\u64ec\u5171\u901a\u793a\u7bc4 \u5f9e\u554f\u984c\u5230\u7a0b\u5f0f\u7684\u5b8c\u6574\u6d41\u7a0b \u7b2c 3 \u9031 \u984c\u76ee\u6536\u6582\u8207 RQ \u5beb\u6cd5 \u78ba\u5b9a\u81ea\u5df1\u7684\u7814\u7a76\u554f\u984c \u7b2c 4 \u9031 \u5c08\u984c\u8a08\u756b\u66f8\uff08Proposal\uff09 \u63d0\u4ea4 1 \u9801\u8a08\u756b\u66f8 \u7b2c 5 \u9031 \u7a0b\u5f0f\u67b6\u69cb\u8207\u521d\u7248\u6a21\u578b \u6838\u5fc3\u7a0b\u5f0f\u53ef\u57f7\u884c \u7b2c 6 \u9031 \u4e2d\u671f\u5206\u4eab \u53e3\u982d\u8aaa\u660e\u73fe\u6cc1\u3001\u63a5\u53d7\u540c\u5b78\u56de\u994b \u7b2c 7 \u9031 \u53c3\u6578\u6383\u63cf\u8207\uff08\u7c21\u55ae\uff09\u6700\u4f73\u5316 \u7d50\u679c\u5206\u6790\u8207\u6bd4\u8f03 \u7b2c 8 \u9031 \u5831\u544a\u67b6\u69cb\u8207\u5beb\u4f5c \u8349\u7a3f\u5b8c\u6210 \u7b2c 9 \u9031 \u7c21\u5831\u8207\u53e3\u982d\u554f\u7b54 10 \u5206\u9418\u53e3\u982d\u5831\u544a \u7b2c 10 \u9031 \u671f\u672b\u5c55\u793a\u8207\u6536\u5c3e \u5b8c\u6574\u5831\u544a\u7e73\u4ea4"},{"location":"courses/level-2/#_3","title":"\u671f\u672b\u6210\u679c","text":"<ul> <li>Project Report\uff1a6\u201310 \u9801\uff0c\u542b Introduction\u3001Methodology\u3001Results\u3001Discussion\u3001Conclusion</li> <li>Slide Deck\uff1a10\u201312 \u5f35\uff0c\u53e3\u982d\u5831\u544a\u7528</li> <li>\u7a0b\u5f0f\u78bc\uff1a\u53ef\u57f7\u884c\u3001\u6709\u7d50\u69cb\u7684 Python \u6a94\u6848</li> </ul> <p>\u9019\u4efd\u5831\u544a\u53ef\u76f4\u63a5\u4f5c\u70ba\uff1aIB Math IA\u3001AP Research \u7684\u90e8\u5206\u6750\u6599\u3001\u5b78\u7fd2\u6b77\u7a0b\u9644\u4ef6\u3001\u5927\u5b78\u7533\u8acb\u4f5c\u54c1\u3002</p>"},{"location":"courses/level-2/#_4","title":"\u8ab2\u7a0b\u898f\u683c","text":"\u9805\u76ee \u8aaa\u660e \u7d1a\u5225\u5b9a\u50f9 NT$30,000 \u5148\u4fee Level 1 \u6216\u540c\u7b49\u7a0b\u5ea6 \u6bcf\u9031\u4e0a\u8ab2 2 \u5c0f\u6642\u5c0f\u73ed\u8ab2 \u500b\u5225\u6307\u5c0e \u6bcf\u4eba\u6bcf\u9031 1 \u5c0f\u6642 1-on-1 \u7e3d\u6642\u6578 \u7d04 30 \u5c0f\u6642 <p>\u2190 Level 1 Level 3 \u2192</p>"},{"location":"courses/level-3/","title":"Level 3\uff1a\u6578\u503c\u65b9\u6cd5\u8207\u512a\u5316","text":"<p>NumPy\u3001SciPy\u3001\u6700\u4f73\u5316\u2014\u2014\u5f9e\u300c\u53ef\u4ee5\u8dd1\u300d\u5230\u300c\u8dd1\u5f97\u6709\u6548\u7387\u53c8\u6b63\u78ba\u300d</p>"},{"location":"courses/level-3/#_1","title":"\u8ab2\u7a0b\u76ee\u6a19","text":"<p>\u5b8c\u6210 Level 3 \u7684\u5b78\u751f\u80fd\u5920\uff1a</p> <ul> <li>\u4f7f\u7528 NumPy \u9032\u884c\u9663\u5217\u904b\u7b97\u8207\u5411\u91cf\u5316</li> <li>\u4f7f\u7528 SciPy \u6c42\u89e3\u5fae\u5206\u65b9\u7a0b\uff08ODE\uff09\u8207\u6700\u4f73\u5316\u554f\u984c</li> <li>\u8a2d\u8a08\u9ad8\u7d1a\u5c08\u984c\uff0c\u7d50\u5408\u6578\u503c\u65b9\u6cd5\u8207\u771f\u5be6\u554f\u984c</li> <li>\u9032\u884c\u5b8c\u6574\u7684\u654f\u611f\u5ea6\u5206\u6790\u8207\u53c3\u6578\u6700\u4f73\u5316</li> </ul>"},{"location":"courses/level-3/#_2","title":"\u9069\u5408\u5c0d\u8c61","text":"<ul> <li>\u5b8c\u6210 Level 2 \u7684\u5b78\u751f</li> <li>\u5c0d\u6578\u5b78\u5efa\u6a21\u6709\u8208\u8da3\uff0c\u60f3\u6df1\u5165 scientific computing</li> <li>\u8003\u616e\u7533\u8acb\u7406\u5de5\u79d1\u5927\u5b78\uff0c\u9700\u8981\u66f4\u5f37\u7684\u6280\u8853\u4f5c\u54c1\u96c6</li> </ul>"},{"location":"courses/level-3/#10","title":"10 \u9031\u8ab2\u7a0b\u5927\u7db1","text":"\u9031\u6b21 \u4e3b\u984c \u6838\u5fc3\u6280\u80fd \u7b2c 1 \u9031 \u76ee\u6a19\u8207\u820a\u5c08\u984c\u56de\u9867 \u627e\u51fa\u53ef\u4ee5\u5347\u7d1a\u7684\u65b9\u5411 \u7b2c 2 \u9031 NumPy\uff1a\u9663\u5217\u8207\u5411\u91cf\u5316 <code>ndarray</code>\u3001broadcasting\u3001\u6548\u80fd \u7b2c 3 \u9031 SciPy\uff1a\u57fa\u672c\u6578\u503c\u65b9\u6cd5 \u6578\u503c\u7a4d\u5206\u3001\u6839\u6c42\u89e3 \u7b2c 4 \u9031 SciPy\uff1a\u7c21\u55ae ODE \u6a21\u578b <code>solve_ivp</code>\u3001SIR \u9032\u968e\u7248 \u7b2c 5 \u9031 \u6700\u4f73\u5316\u5165\u9580 <code>scipy.optimize</code>\u3001\u76ee\u6a19\u51fd\u6578\u8a2d\u8a08 \u7b2c 6 \u9031 \u9ad8\u7d1a\u5c08\u984c\u9078\u984c\u8207\u65b9\u6cd5\u8a2d\u8a08 \u5b9a\u7fa9\u554f\u984c\u7684\u6578\u5b78\u7d50\u69cb \u7b2c 7 \u9031 \u5c08\u984c\u5be6\u4f5c\uff1a\u6a21\u578b\u8207\u6578\u503c\u65b9\u6cd5 \u6838\u5fc3\u7a0b\u5f0f\u5b8c\u6210 \u7b2c 8 \u9031 \u5c08\u984c\u5be6\u4f5c\uff1a\u6700\u4f73\u5316\u8207\u654f\u611f\u5ea6\u5206\u6790 \u7d50\u679c\u5206\u6790 \u7b2c 9 \u9031 \u6280\u8853\u5beb\u4f5c\u8207\u7c21\u5831 \u5831\u544a\u8349\u7a3f \u7b2c 10 \u9031 \u4f5c\u54c1\u96c6\u5c55\u793a\u8207\u6574\u7406 \u5b8c\u6574\u4f5c\u54c1\u96c6\u7e73\u4ea4"},{"location":"courses/level-3/#_3","title":"\u671f\u672b\u6210\u679c","text":"<ul> <li>\u9032\u968e Project Report\uff1a8\u201312 \u9801\uff0c\u542b\u6578\u503c\u65b9\u6cd5\u8aaa\u660e\u8207\u6700\u4f73\u5316\u5be6\u9a57</li> <li>Python \u7a0b\u5f0f\u78bc\uff1a\u6a21\u7d44\u5316\u7d50\u69cb\uff0c\u9644 docstring</li> <li>\u4f5c\u54c1\u96c6\u66f4\u65b0\uff1a\u6574\u5408 Level 1\u20133 \u4f5c\u54c1\u96c6</li> </ul>"},{"location":"courses/level-3/#_4","title":"\u8ab2\u7a0b\u898f\u683c","text":"\u9805\u76ee \u8aaa\u660e \u7d1a\u5225\u5b9a\u50f9 NT$30,000 \u5148\u4fee Level 2 \u6216\u540c\u7b49\u7a0b\u5ea6 \u6bcf\u9031\u4e0a\u8ab2 2 \u5c0f\u6642\u5c0f\u73ed\u8ab2 \u500b\u5225\u6307\u5c0e \u6bcf\u4eba\u6bcf\u9031 1 \u5c0f\u6642 1-on-1 \u7e3d\u6642\u6578 \u7d04 30 \u5c0f\u6642 <p>\u2190 Level 2 Level 4 \u2192</p>"},{"location":"courses/level-4/","title":"Level 4\uff1aResearch Capstone","text":"<p>\u5f9e\u5b78\u751f\u8b8a\u7814\u7a76\u8005\u2014\u2014\u5b8c\u6210\u4e00\u4efd\u771f\u6b63\u53ef\u4ee5\u6295\u7a3f\u3001\u53ef\u4ee5\u7533\u8acb\u5927\u5b78\u7684\u7814\u7a76\u5831\u544a</p>"},{"location":"courses/level-4/#_1","title":"\u8ab2\u7a0b\u76ee\u6a19","text":"<p>\u5b8c\u6210 Level 4 \u7684\u5b78\u751f\u80fd\u5920\uff1a</p> <ul> <li>\u7368\u7acb\u9032\u884c\u6587\u737b\u641c\u5c0b\u8207\u5206\u6790\uff08Google Scholar\u3001Semantic Scholar\uff09</li> <li>\u627e\u51fa\u6587\u737b gap\uff0c\u5b9a\u7fa9\u6709\u7814\u7a76\u8ca2\u737b\u7684\u554f\u984c</li> <li>\u5b8c\u6210\u4e00\u4efd 10\u201315 \u9801\u7684\u7814\u7a76\u578b\u5831\u544a\uff08\u542b Literature Review\uff09</li> <li>\u9032\u884c\u6a21\u64ec\u53e3\u8a66\u554f\u7b54\uff0c\u6e96\u5099\u5927\u5b78\u9762\u8a66\u6216\u7af6\u8cfd\u7b54\u8faf</li> </ul>"},{"location":"courses/level-4/#_2","title":"\u9069\u5408\u5c0d\u8c61","text":"<ul> <li>\u5b8c\u6210 Level 3 \u7684\u5b78\u751f</li> <li>\u6709\u610f\u7533\u8acb Top 50 \u5168\u7403\u5927\u5b78\uff0c\u9700\u8981\u7814\u7a76\u578b\u4f5c\u54c1</li> <li>\u53c3\u52a0 \u79d1\u5c55\u3001ISEF\u3001Regeneron \u7b49\u7af6\u8cfd\u7684\u5b78\u751f</li> <li>\u5c0d\u67d0\u500b\u9818\u57df\u6709\u771f\u6b63\u7684\u7814\u7a76\u8208\u8da3</li> </ul>"},{"location":"courses/level-4/#10","title":"10 \u9031\u8ab2\u7a0b\u5927\u7db1","text":"\u9031\u6b21 \u4e3b\u984c \u6838\u5fc3\u4efb\u52d9 \u7b2c 1 \u9031 \u7814\u7a76\u578b\u5c08\u984c vs \u4e00\u822c project \u7406\u89e3\u300c\u7814\u7a76\u8ca2\u737b\u300d\u662f\u4ec0\u9ebc \u7b2c 2 \u9031 \u6587\u737b\u641c\u5c0b\u7b56\u7565 Google Scholar\u3001\u95dc\u9375\u5b57\u8a2d\u8a08 \u7b2c 3 \u9031 \u6587\u737b\u95b1\u8b80\u8207\u5206\u6790\u77e9\u9663 \u6574\u7406 5\u20138 \u7bc7\u6587\u737b \u7b2c 4 \u9031 \u6587\u737b\u56de\u9867\u5beb\u4f5c Literature Review \u8349\u7a3f \u7b2c 5 \u9031 \u7814\u7a76\u554f\u984c\u8207 gap \u7cbe\u7149 \u78ba\u5b9a\u53ef\u8ca2\u737b\u7684\u65b9\u5411 \u7b2c 6 \u9031 \u65b9\u6cd5\u7ae0\u8a2d\u8a08\u8207\u5beb\u4f5c Methodology \u5b8c\u6210 \u7b2c 7 \u9031 \u5be6\u9a57\u8207\u7d50\u679c\u5448\u73fe\uff08\u7814\u7a76\u7248\uff09 Results + \u5716\u8868 \u7b2c 8 \u9031 \u8a0e\u8ad6\u3001\u9650\u5236\u8207\u672a\u4f86\u5de5\u4f5c Discussion \u5b8c\u6210 \u7b2c 9 \u9031 \u5168\u6587\u6574\u5408\u8207\u5b78\u8853\u5beb\u4f5c\u7d30\u7bc0 \u5b8c\u6574\u5831\u544a\u8349\u7a3f \u7b2c 10 \u9031 \u7814\u7a76\u7c21\u5831\u8207\u53e3\u8a66\u6a21\u64ec \u6a21\u64ec 15 \u5206\u9418\u53e3\u8a66"},{"location":"courses/level-4/#_3","title":"\u671f\u672b\u6210\u679c","text":"<ul> <li>Research Report\uff1a10\u201315 \u9801\uff0c\u5b78\u8853\u683c\u5f0f\uff08\u542b Literature Review\u3001Methodology\u3001Results\u3001Discussion\uff09</li> <li>Slide Deck\uff1a14\u201316 \u5f35\uff0c\u53e3\u8a66\u7c21\u5831</li> <li>\u53e3\u8a66\u6a21\u64ec\uff1a15 \u5206\u9418 presentation + 10 \u5206\u9418 Q&amp;A</li> </ul> <p>\u9019\u4efd\u5831\u544a\u53ef\u76f4\u63a5\u7528\u65bc\uff1a\u5927\u5b78\u7533\u8acb Additional Information\u3001Portfolio\u3001\u79d1\u5c55\u521d\u5be9\u3001\u5b78\u8853\u7af6\u8cfd\u3002</p>"},{"location":"courses/level-4/#_4","title":"\u8ab2\u7a0b\u898f\u683c","text":"\u9805\u76ee \u8aaa\u660e \u7d1a\u5225\u5b9a\u50f9 NT$34,000 \u5148\u4fee Level 3 \u6216\u540c\u7b49\u7a0b\u5ea6 \u6bcf\u9031\u4e0a\u8ab2 2 \u5c0f\u6642\u5c0f\u73ed\u8ab2 \u500b\u5225\u6307\u5c0e \u6bcf\u4eba\u6bcf\u9031 1 \u5c0f\u6642 1-on-1 \u7e3d\u6642\u6578 \u7d04 30 \u5c0f\u6642 <p>\u2190 Level 3 \u67e5\u770b\u5b9a\u50f9\u65b9\u6848 \u2192</p>"}]}